# Example environment variables for local development
# Copy this file to .env and fill in the actual values for your environment

# MongoDB Atlas connection string (replace <username> and <password>)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.ow8zwco.mongodb.net/medivault?retryWrites=true&w=majority
MONGO_DB_NAME=medivault

# AWS credentials for S3 access
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-south-1
S3_BUCKET_NAME=your-bucket-name

# JWT settings (use a strong random secret)
JWT_SECRET_KEY=replace_with_a_strong_random_secret_at_least_32_chars_123456
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini API key (if used)
GEMINI_API_KEY=your_gemini_api_key

# Notification/email settings (optional)
NOTIFICATION_EMAIL=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
